# Copy to .env.local and fill in values for local development.
# All NEXT_PUBLIC_ vars are exposed to the browser. Never put secrets in NEXT_PUBLIC_ vars.

# Required — WebSocket signaling server base URL. No trailing slash.
# e.g. https://signal.callsafe.tech (production) or http://localhost:4000 (local dev)
NEXT_PUBLIC_SIGNALING_SERVER_URL=

# Required — Vercel Postgres connection string.
# Vercel Dashboard → Storage → your database → .env.local tab
POSTGRES_URL=

# Required — HMAC signing key for JWT. Must be 32+ characters. Must match the
# value set on the Elixir signaling server.
# Generate: openssl rand -base64 32
JWT_SECRET=

# Optional — STUN servers for ICE candidate gathering. Defaults to Google STUN.
# NEXT_PUBLIC_STUN_SERVER_1=stun:stun.l.google.com:19302
# NEXT_PUBLIC_STUN_SERVER_2=stun:stun1.l.google.com:19302

# Optional — Static TURN fallback used only if the dynamic /turn-credentials fetch
# from the Elixir server fails. Leave blank when the signaling server is reachable.
# NEXT_PUBLIC_TURN_SERVER_URL=
# NEXT_PUBLIC_TURN_USERNAME=
# NEXT_PUBLIC_TURN_CREDENTIAL=

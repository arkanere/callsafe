# Signaling Server Configuration
VITE_SIGNALING_SERVER_URL=wss://your-signaling-server.com
VITE_API_BASE_URL=https://your-signaling-server.com/api

# WebRTC STUN Server Configuration
VITE_STUN_SERVER_1=stun:stun.l.google.com:19302
VITE_STUN_SERVER_2=stun:stun1.l.google.com:19302

# WebRTC TURN Server Configuration (Metered.ca)
VITE_TURN_SERVER_URL=turn:a.relay.metered.ca:80
VITE_TURN_USERNAME=your-metered-username
VITE_TURN_CREDENTIAL=your-metered-password

# Environment
VITE_NODE_ENV=production
# Production environment variables — all components
# Copy the relevant section to each deployment target and fill in values.
# Never commit actual secrets.

# =============================================================================
# ELIXIR SIGNALING SERVER (fly.io / VPS)
# =============================================================================

# Required — HMAC signing key for JWT. Must be 32+ characters.
# Generate: openssl rand -base64 32
JWT_SECRET=

# Required — Firebase service account JSON for FCM HTTP v2 push notifications.
# Google Cloud Console → IAM → Service Accounts → Create key (JSON).
# Grant the "Firebase Cloud Messaging API Sender" role.
# Paste the full JSON contents as the value (single line, no newlines).
FCM_SERVICE_ACCOUNT_JSON=

# Optional — TCP port to listen on. Default: 4000
# PORT=4000

# Required — TURN server URIs (comma-separated) for calls behind symmetric NAT
# or corporate firewalls. Without TURN, those calls fail silently.
# e.g. turn:a.relay.metered.ca:80,turn:a.relay.metered.ca:443,turns:a.relay.metered.ca:443?transport=tcp
TURN_SERVER_URL=

# Required — Shared secret for HMAC time-limited TURN credential generation (RFC 8656)
# Obtain from your TURN provider (Metered.ca: API key acts as shared secret)
TURN_SECRET=

# Optional — Identifier embedded in time-limited TURN username. Default: callsafe
# TURN_USERNAME=callsafe

# =============================================================================
# FRONTEND (Vercel)
# =============================================================================

# Required — Must match JWT_SECRET above. Used to verify socket-token JWTs.
# JWT_SECRET=

# Required — Vercel Postgres connection string.
# Vercel Dashboard → Storage → your database → .env.local tab
# POSTGRES_URL=

# Required — WebSocket signaling server base URL. No trailing slash.
# e.g. https://tunnel.callsafe.tech
# VITE_SIGNALING_SERVER_URL=

# Optional — STUN servers for ICE candidate gathering. Defaults to Google STUN.
# VITE_STUN_SERVER_1=stun:stun.l.google.com:19302
# VITE_STUN_SERVER_2=stun:stun1.l.google.com:19302

# Optional — Static TURN fallback used only if dynamic /turn-credentials fetch fails.
# Leave blank when the Elixir server is reachable (it generates time-limited credentials).
# VITE_TURN_SERVER_URL=
# VITE_TURN_USERNAME=
# VITE_TURN_CREDENTIAL=

# Copy to .env and fill in values before running `make server-up`

# Required — must be at least 32 characters (used for JWT HMAC signing)
# Generate: openssl rand -base64 32
JWT_SECRET=change_me_to_a_long_random_secret_32chars_min

# Required — Firebase service account JSON for FCM push notifications (HTTP v2 API).
# Google Cloud Console → IAM → Service Accounts → Create key (JSON).
# Grant the "Firebase Cloud Messaging API Sender" role.
# Paste the full JSON contents as the value (single line, no internal newlines).
FCM_SERVICE_ACCOUNT_JSON=

# Optional — override the listening port (default: 4000)
# PORT=4000

# Optional — comma-separated origins allowed for cross-origin HTTP requests
# (guest-token endpoint etc.). Use "*" to allow any origin. In dev, defaults
# to the local Vite origins (http://localhost:5173, http://localhost:4173).
# CORS_ALLOWED_ORIGINS=https://app.callsafe.tech,https://example-customer.com

# TURN server — required for calls behind symmetric NAT / corporate firewalls
# TURN_SERVER_URL: comma-separated TURN URIs
#   e.g. turn:a.relay.metered.ca:80,turn:a.relay.metered.ca:443,turns:a.relay.metered.ca:443?transport=tcp
# TURN_SECRET: shared secret for HMAC time-limited credential generation (RFC 8656)
# TURN_USERNAME: identifier embedded in the time-limited username (default: callsafe)
TURN_SERVER_URL=
TURN_SECRET=
# TURN_USERNAME=callsafe

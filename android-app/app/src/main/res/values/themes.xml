<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.CallSafe" parent="Theme.MaterialComponents.Light.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/button_blue_600</item>
        <item name="colorPrimaryVariant">@color/button_blue_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/button_blue_600</item>
        <item name="colorSecondaryVariant">@color/button_blue_700</item>
        <item name="colorOnSecondary">@color/white</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/button_blue_700</item>
        <!-- Ensure text input fields have proper contrast -->
        <item name="colorOnSurface">@color/text_gray_900</item>
        <item name="android:textColorPrimary">@color/text_gray_900</item>
    </style>

    <!-- Theme for incoming call activity -->
    <style name="Theme.CallSafe.IncomingCall" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowFullscreen">true</item>
    </style>
</resources>
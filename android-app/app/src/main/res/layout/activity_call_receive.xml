<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center"
    android:background="#000000">

    <!-- Status Display -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CallSafe"
        android:textSize="32sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"
        android:gravity="center" />

    <!-- Caller Information -->
    <TextView
        android:id="@+id/callerInfoText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Caller Information"
        android:textSize="18sp"
        android:textColor="#CCCCCC"
        android:layout_marginBottom="32dp"
        android:gravity="center"
        android:visibility="gone" />

    <!-- Device Status (Multi-device info) -->
    <TextView
        android:id="@+id/deviceStatusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Device Status"
        android:textSize="14sp"
        android:textColor="#888888"
        android:layout_marginBottom="48dp"
        android:gravity="center"
        android:visibility="gone" />

    <!-- Button Container -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <!-- Accept Call Button -->
        <Button
            android:id="@+id/acceptButton"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:text="Accept"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/button_accept"
            android:layout_margin="16dp"
            android:visibility="gone" />

        <!-- Decline Call Button -->
        <Button
            android:id="@+id/declineButton"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:text="Decline"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/button_decline"
            android:layout_margin="16dp"
            android:visibility="gone" />

        <!-- End Call Button -->
        <Button
            android:id="@+id/endButton"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:text="End"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/button_end"
            android:layout_margin="16dp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Mute Button (separate row) -->
    <Button
        android:id="@+id/muteButton"
        android:layout_width="100dp"
        android:layout_height="60dp"
        android:text="Mute"
        android:textSize="14sp"
        android:textColor="#FFFFFF"
        android:background="@drawable/button_mute"
        android:layout_marginTop="24dp"
        android:visibility="gone" />

</LinearLayout>